# ---- Secrets (required) --------------------------------------------------
# --- Discord delivery: use EITHER a bot OR a webhook (bot preferred) -------
# Option A (bot): create a bot at https://discord.com/developers/applications,
# invite it to your server with "Send Messages" + "Embed Links" permission.
DISCORD_BOT_TOKEN=
# Enable Developer Mode, right-click the target channel -> Copy Channel ID
DISCORD_CHANNEL_ID=
# Option B (webhook): a REAL webhook URL, not a channel link.
# Must look like https://discord.com/api/webhooks/<id>/<token>
DISCORD_WEBHOOK_URL=

# AI provider key. OpenAI key (sk-...) or Google AI Studio key.
AI_API_KEY=

# --- IPO data provider keys (OPTIONAL) -------------------------------------
# Facts fall back to NSE/BSE (no key) if these are blank, but IPOAlerts gives a
# much broader list and includes GMP on the same call. Leave blank to skip.
#
# IPOGuru (email ipoguru.in@gmail.com for a key) — GMP aggregator fallback only:
PRIMARY_API_KEY=
# IPOAlerts (create a key at https://ipoalerts.in/signup) — facts PRIMARY source:
FALLBACK_API_KEY=

# ---- AI settings (optional) ----------------------------------------------
# "openai" (default) or "gemini"
AI_PROVIDER=openai
# Model id. Defaults: openai -> gpt-4o-mini, gemini -> gemini-1.5-flash
AI_MODEL=gpt-4o-mini

# ---- Behaviour (optional) ------------------------------------------------
# How many days ahead to scan for IPOs
LOOKAHEAD_DAYS=21
# Daily run time (24h clock) and timezone (IANA name, e.g. Asia/Kolkata)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
TIMEZONE=UTC
# SQLite state file used for de-duplication
DB_PATH=state.db
# Run one check immediately when the process starts
RUN_ON_START=true
